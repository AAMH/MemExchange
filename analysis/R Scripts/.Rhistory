print(plot)
# Load necessary libraries
library(ggplot2)
min_time <- 200
max_time <- 1000
min_lat <- 0
max_lat <- 15
# Read the CSV files
data_rdma <- read.csv("/Users/amh/Downloads/800/output_CS_rdma.csv")
data_tcp <- read.csv("/Users/amh/Downloads/800/output_CS_tcp.csv")
# Extract the 8th column ("avg_lat") and add a time column
data_rdma$time <- 1:nrow(data_rdma)
data_tcp$time <- 1:nrow(data_tcp)
avg_lat_rdma <- data_rdma[,8]
avg_lat_tcp <- data_tcp[,8]
# Combine data into one dataframe for plotting
data_combined <- data.frame(
time = c(data_rdma$time, data_tcp$time),
avg_lat = c(avg_lat_rdma, avg_lat_tcp),
type = c(rep("RDMA_based", nrow(data_rdma)), rep("TCP_based", nrow(data_tcp)))
)
# Create the plot
plot <- ggplot(data_combined, aes(x = time, y = avg_lat, color = type)) +
geom_line() +
labs(title = "Comparison of Average Latency Over Time",
x = "Time (seconds)",
y = "Average Latency(milliseconds)",
color = "Type") +
theme_minimal() +
xlim(min_time, max_time) +
ylim(min_lat, max_lat)
# Save the plot as a PDF
ggsave("comparison_plot.pdf", plot = plot)
# Display the plot
print(plot)
